# ============================================================
#  Rugged — environment template
#  Copy this file to .env and fill every value before Phase 1.
#  .env is gitignored — never commit real keys.
# ============================================================

# ---- Circle (Developer Console: console.circle.com) --------
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=

# ---- Arc testnet --------------------------------------------
# ARC_RPC_URL: from the Arc CLI / Canteen onboarding
# ARC_CHAIN_ID: output of `arc-canteen rpc eth_chainId` (decimal)
ARC_RPC_URL=
ARC_CHAIN_ID=
# DEPLOYER_PRIVATE_KEY: a funded Arc testnet key — deploys all contracts.
#   NOT in the project.md key table but required for Phase 1 deployment.
DEPLOYER_PRIVATE_KEY=
# TREASURY_ADDRESS: receives the 1.2% protocol fee (Resolution.sol)
TREASURY_ADDRESS=
# OPERATOR_ADDRESS: the only address allowed to call TraceRegistry.registerTrace
OPERATOR_ADDRESS=
# USDC_ADDRESS: Arc testnet USDC token contract
USDC_ADDRESS=
# USYC_ADDRESS: Arc testnet USYC token contract
USYC_ADDRESS=

# ---- GitHub commit watcher (Phase 2) ------------------------
GITHUB_TOKEN=

# ---- Agent B — Social Listener (Phase 3) --------------------
# developer.x.com — pay-per-use, load ~$30, set a $35 hard cap
X_BEARER_TOKEN=

# ---- Price oracles ------------------------------------------
COINGECKO_API_KEY=
PYTH_RPC_URL=

# ---- Telegram alert bot (Phase 7) ---------------------------
TELEGRAM_BOT_TOKEN=

# ---- Reasoning trace pinning (Phase 4) ----------------------
IRYS_PRIVATE_KEY=

# ---- Agent A — Contract Inspector (Phase 3) -----------------
# GoPlus uses an App Key + App Secret pair, not a single API key.
# Generate at https://console.gopluslabs.io → App Management.
# Each request signs sha1(app_key + timestamp + app_secret) to mint a short-lived token.
GOPLUS_APP_KEY=
GOPLUS_APP_SECRET=

# ---- LLM reasoning layer (agents) ---------------------------
# Agents are "Claude or GPT class" — Claude is the default.
#   NOT in the project.md key table but required for Phase 3.
ANTHROPIC_API_KEY=

# ---- Deployed contract addresses ----------------------------
# Left blank now — filled automatically after the Phase 1 deploy.
MARKET_FACTORY_ADDRESS=
MARKET_RESOLUTION_ADDRESS=
REPUTATION_BOND_ADDRESS=
TRACE_REGISTRY_ADDRESS=
