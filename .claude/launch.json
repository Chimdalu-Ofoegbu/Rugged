{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "static: serve (project/)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["--yes", "serve", "project", "-l", "5180", "--no-clipboard", "--no-port-switching"],
      "port": 5180
    },
    {
      "name": "static: http-server (project/)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["--yes", "http-server", "project", "-p", "5181", "-c-1", "--silent"],
      "port": 5181
    }
  ]
}
