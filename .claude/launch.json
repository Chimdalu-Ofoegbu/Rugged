{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "static: serve (project/)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["--yes", "serve", "project", "--no-clipboard"],
      "port": 5180,
      "autoPort": true
    },
    {
      "name": "static: http-server (project/)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["--yes", "http-server", "project", "-c-1", "--silent"],
      "port": 5181,
      "autoPort": true
    }
  ]
}
